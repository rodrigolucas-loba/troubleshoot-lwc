<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <validationRules>
        <fullName>Contact</fullName>
        <active>true</active>
        <description>Validates that Contact Mailing Zip matches Account Shipping Zip if an Account is present.</description>
        <errorConditionFormula>AND(
    NOT(ISBLANK(AccountId)),
    MailingPostalCode &lt;&gt; Account.ShippingPostalCode
)</errorConditionFormula>
        <errorMessage>The Contact Mailing Zip Code must match the Account Shipping Zip Code.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Contact_must_be_in_Account_ZIP_Code</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
    NOT(ISBLANK(AccountId)),
    MailingPostalCode &lt;&gt; Account.ShippingPostalCode
)</errorConditionFormula>
        <errorMessage>The Contact Mailing Zip Code must match the Account Shipping Zip Code.</errorMessage>
    </validationRules>
</CustomObject>
